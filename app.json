{
  "expo": {
    "name": "FliponeX",
    "slug": "customerandroidapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.fliponex.customer",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b218656e-1386-4996-b985-6f29049bf832"
      }
    },
    "plugins": [
      "./plugins/withUCropStatusBar",
      "./plugins/withRemoveAudioPermission",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a"]
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FliponeX needs camera access to capture documents during booking."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FliponeX needs access to your photos to upload documents.",
          "cameraPermission": "FliponeX needs camera access to capture documents."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FliponeX uses your location to detect your service address.",
          "locationWhenInUsePermission": "FliponeX uses your location to detect your service address."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-notifications"
    ],
    "owner": "nishanthbannu"
  }
}
