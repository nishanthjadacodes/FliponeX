# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Firebase
# google-services.json is safe to commit — it contains Firebase project IDs,
# not secrets. Security is enforced by the SHA-1 fingerprint registered in
# the Firebase Console, not by keeping this file private. This matches
# Expo's official recommendation: https://docs.expo.dev/guides/using-firebase/

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
# Release-signing credentials — NEVER commit. Generated locally and
# referenced from android/app/build.gradle's release signingConfig.
android/release-signing.properties

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
